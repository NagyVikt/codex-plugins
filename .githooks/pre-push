#!/usr/bin/env bash
set -euo pipefail

hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$hook_dir/.." && pwd)"
sync_script="$repo_root/scripts/sync_plugins_to_marketplace.py"
marketplace_rel=".agents/plugins/marketplace.json"

if [[ ! -x "$sync_script" ]]; then
  echo "[pre-push] Missing or non-executable sync script: $sync_script" >&2
  echo "[pre-push] Run: chmod +x \"$sync_script\"" >&2
  exit 1
fi

echo "[pre-push] Syncing plugins into marketplace.json..."

was_dirty=0
if ! git -C "$repo_root" diff --quiet -- "$marketplace_rel"; then
  was_dirty=1
fi

"$sync_script"

if ! git -C "$repo_root" diff --quiet -- "$marketplace_rel"; then
  if [[ "$was_dirty" -eq 0 ]]; then
    echo "[pre-push] marketplace.json was updated by sync." >&2
  else
    echo "[pre-push] marketplace.json has uncommitted changes." >&2
  fi
  echo "[pre-push] Commit the changes, then run git push again." >&2
  exit 1
fi

echo "[pre-push] Plugin marketplace is up to date."
